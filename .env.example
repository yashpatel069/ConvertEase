# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb://127.0.0.1:27017/convertease

# Authentication
JWT_SECRET=your_jwt_access_secret_key_change_me
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_me

# Storage Configuration
# Options: local, s3, cloudinary
STORAGE_PROVIDER=local

# AWS S3 Storage Config (Required if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET_NAME=convertease-files

# Cloudinary Storage Config (Required if STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
